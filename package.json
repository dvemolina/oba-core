{
	"name": "oba-core",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"build": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && vite build",
		"preview": "vite preview",
		"prepare": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync || echo ''",
		"check": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && vitest run --project server",
		"test:unit:watch": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && vitest --project server",
		"test:browser": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && vitest --project client",
		"test": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && vitest run --project server && playwright test",
		"test:e2e": "playwright test",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"db:seed": "npx tsx --env-file=.env src/lib/server/seed.ts",
		"db:reset-auth": "npx tsx --env-file=.env src/lib/server/reset-auth.ts"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.10.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22",
		"@types/nodemailer": "^8.0.0",
		"@vitest/browser-playwright": "^4.1.0",
		"better-auth": "~1.4.21",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"lucide-svelte": "0.475.0",
		"nodemailer": "^8.0.10",
		"postgres": "^3.4.8"
	},
	"packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
